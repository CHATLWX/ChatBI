# Qwen cloud API (Alibaba Cloud Model Studio). Never commit a real key.
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus
LLM_MAX_TOKENS=4000

# Local MySQL (keep the real password only in your local environment)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=chatbi

# Milvus in Docker
MILVUS_URI=http://localhost:19530
MILVUS_TOKEN=
MILVUS_DB_NAME=default

# Obsidian indicator knowledge base. Leave empty to auto-detect the open vault.
OBSIDIAN_VAULT_PATH=
OBSIDIAN_INDICATOR_FOLDER=ChatBI指标知识库
OBSIDIAN_AUTO_DISCOVER=true
OBSIDIAN_RUNTIME_PREFERRED=true
